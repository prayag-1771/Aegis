      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Space+Grotesk:wght@300;500;700&display=swap');\n\n  :root {\n    --obsidian: #0B0C10;\n    --slate: #1F2833;\n    --cyan: #45A29E;\n    --cyan-glow: rgba(69, 162, 158, 0.4);\n    --rose: #E07A5F;\n    --font-space: 'Space Grotesk', sans-serif;\n    --font-inter: 'Inter', sans-serif;\n  }\n\n  body {\n    margin: 0;\n    padding: 0;\n    font-family: var(--font-inter);\n    background: #050505;\n    color: #C5C6C7;\n    overflow: hidden;\n    height: 100vh;\n  }\n\n  .pellucid-glass {\n    background: rgba(11, 12, 16, 0.4);\n    backdrop-filter: blur(24px);\n    -webkit-backdrop-filter: blur(24px);\n    border: 1px solid rgba(255, 255, 255, 0.05);\n    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);\n  }\n\n  .signature-geometry {\n    border-radius: 4px; /* Sharp outer */\n  }\n\n  .inner-geometry {\n    border-radius: 12px; /* Fluid inner */\n  }\n\n  /* Custom Scrollbar for Pretext density */\n  .custom-scroll::-webkit-scrollbar {\n    width: 2px;\n  }\n  .custom-scroll::-webkit-scrollbar-thumb {\n    background: var(--cyan);\n    border-radius: 10px;\n  }\n\n  /* Map overlay mask */\n  .map-vignette {\n    position: absolute;\n    inset: 0;\n    background: radial-gradient(circle at center, transparent 0%, rgba(5, 5, 5, 0.4) 100%);\n    pointer-events: none;\n    z-index: 1;\n  }\n\n  .nav-bucket {\n    z-index: 50;\n  }\n\n  .nav-item {\n    transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);\n    position: relative;\n  }\n\n  .nav-item.active::after {\n    content: '';\n    position: absolute;\n    bottom: -8px;\n    left: 20%;\n    right: 20%;\n    height: 2px;\n    background: var(--cyan);\n    box-shadow: 0 0 12px var(--cyan-glow);\n    border-radius: 99px;\n  }\n\n  .staggered-card {\n    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);\n  }\n\n  /* Pretext-like density layout */\n  .telemetry-grid {\n    display: grid;\n    grid-template-columns: repeat(2, 1fr);\n    gap: 8px;\n    font-variant-numeric: tabular-nums;\n  }\n\n  .glow-text {\n    text-shadow: 0 0 8px var(--cyan-glow);\n  }\n</style>\n\n<div class=\"absolute inset-0 z-0\" data-dynamic=\"true\" data-kid=\"1\" data-name=\"background map visualization container\" data-reason=\"map rendered into div by MapLibre library\" id=\"map\"></div>\n<div class=\"map-vignette\" data-kid=\"2\" data-name=\"map vignette overlay mask\"></div>\n\n<div class=\"relative h-screen w-full flex flex-col p-6 z-10 pointer-events-none\" data-kid=\"3\" data-name=\"main HUD layout container\">\n\n<header class=\"flex justify-between items-start w-full\" data-kid=\"3-1\" data-name=\"top navigation header\">\n<div class=\"flex items-center gap-4 pointer-events-auto\" data-kid=\"3-1-1\" data-name=\"brand logo and identity container\">\n<div class=\"pellucid-glass signature-geometry p-2.5 flex items-center gap-3\" data-kid=\"3-1-1-1\" data-name=\"brand identity card\">\n<div class=\"w-8 h-8 rounded bg-gradient-to-br from-cyan-400 to-cyan-600 flex items-center justify-center\" data-kid=\"3-1-1-1-1\" data-name=\"shield check icon container\">\n<i class=\"ti ti-shield-check text-black text-lg\" data-kid=\"3-1-1-1-1-1\" data-name=\"shield check icon\"></i>\n</div>\n<span class=\"font-['Space_Grotesk'] font-bold text-white tracking-wider\" data-kid=\"3-1-1-1-2\" data-name=\"brand name text\">AEGIS</span>\n</div>\n</div>\n<nav class=\"nav-bucket fixed top-6 left-1/2 -translate-x-1/2 pointer-events-auto\" data-kid=\"3-1-2\" data-name=\"main navigation menu bar\">\n<div class=\"pellucid-glass signature-geometry p-1 flex gap-1\" data-kid=\"3-1-2-1\" data-name=\"navigation button group\">\n<button class=\"nav-item active px-5 py-2 text-sm font-medium text-white hover:text-cyan-400\" data-kid=\"3-1-2-1-1\" data-name=\"live map navigation link\">Live Map</button>\n<button class=\"nav-item px-5 py-2 text-sm font-medium text-zinc-400 hover:text-white\" data-kid=\"3-1-2-1-2\" data-name=\"modules navigation link\">Modules</button>\n<button class=\"nav-item px-5 py-2 text-sm font-medium text-zinc-400 hover:text-white\" data-kid=\"3-1-2-1-3\" data-name=\"fraud rings navigation link\">Fraud Rings</button>\n<button class=\"nav-item px-5 py-2 text-sm font-medium text-zinc-400 hover:text-white\" data-kid=\"3-1-2-1-4\" data-name=\"alerts navigation link\">Alerts</button>\n<button class=\"nav-item px-5 py-2 text-sm font-medium text-zinc-400 hover:text-white\" data-kid=\"3-1-2-1-5\" data-name=\"analytics navigation link\">Analytics</button>\n</div>\n</nav>\n<div class=\"flex items-center gap-3 pointer-events-auto\" data-kid=\"3-1-3\" data-name=\"utility buttons and profile container\">\n<div class=\"pellucid-glass signature-geometry p-1 flex items-center gap-1\" data-kid=\"3-1-3-1\" data-name=\"utility buttons container\">\n<button class=\"w-10 h-10 flex items-center justify-center text-zinc-400 hover:text-white hover:bg-white/5 rounded\" data-kid=\"3-1-3-1-1\" data-name=\"notification alert button\">\n<i class=\"ti ti-bell text-xl\" data-kid=\"3-1-3-1-1-1\" data-name=\"notification bell icon\"></i>\n</button>\n<button class=\"w-10 h-10 flex items-center justify-center text-zinc-400 hover:text-white hover:bg-white/5 rounded\" data-kid=\"3-1-3-1-2\" data-name=\"settings button\">\n<i class=\"ti ti-settings text-xl\" data-kid=\"3-1-3-1-2-1\" data-name=\"settings gear icon\"></i>\n</button>\n</div>\n<div class=\"pellucid-glass signature-geometry p-1\" data-kid=\"3-1-3-2\" data-name=\"user profile container\">\n<img alt=\"Profile\" class=\"w-10 h-10 rounded\" data-kid=\"3-1-3-2-1\" data-name=\"user profile image\" src=\"https://i.pravatar.cc/100?u=pm_aegis\">\n</div>\n</div>\n</header>\n\n<div class=\"mt-auto mb-auto flex flex-col gap-4 w-64 pointer-events-auto\" data-kid=\"3-2\" data-name=\"sidebar telemetry container\">\n<div class=\"pellucid-glass signature-geometry p-5\" data-kid=\"3-2-1\" data-name=\"telemetry data card\">\n<h2 class=\"font-['Space_Grotesk'] text-xs font-bold uppercase tracking-[0.2em] text-cyan-400 mb-4\" data-kid=\"3-2-1-1\" data-name=\"telemetry section title\">Signal Telemetry</h2>\n<div class=\"telemetry-grid\" data-kid=\"3-2-1-2\" data-name=\"telemetry data grid\">\n<div class=\"flex flex-col\" data-kid=\"3-2-1-2-1\" data-name=\"scam count container\">\n<span class=\"text-[10px] uppercase text-zinc-500 font-semibold\" data-kid=\"3-2-1-2-1-1\" data-name=\"scam label\">Scam</span>\n<span class=\"text-xl font-['Space_Grotesk'] font-bold text-white glow-text\" data-kid=\"3-2-1-2-1-2\" data-name=\"scam value\">142</span>\n</div>\n<div class=\"flex flex-col\" data-kid=\"3-2-1-2-2\" data-name=\"notes count container\">\n<span class=\"text-[10px] uppercase text-zinc-500 font-semibold\" data-kid=\"3-2-1-2-2-1\" data-name=\"notes label\">Notes</span>\n<span class=\"text-xl font-['Space_Grotesk'] font-bold text-white\" data-kid=\"3-2-1-2-2-2\" data-name=\"notes value\">08</span>\n</div>\n<div class=\"flex flex-col\" data-kid=\"3-2-1-2-3\" data-name=\"flagged count container\">\n<span class=\"text-[10px] uppercase text-zinc-500 font-semibold\" data-kid=\"3-2-1-2-3-1\" data-name=\"flagged label\">Flagged</span>\n<span class=\"text-xl font-['Space_Grotesk'] font-bold text-rose-400\" data-kid=\"3-2-1-2-3-2\" data-name=\"flagged value\">29</span>\n</div>\n<div class=\"flex flex-col\" data-kid=\"3-2-1-2-4\" data-name=\"active rings count container\">\n<span class=\"text-[10px] uppercase text-zinc-500 font-semibold\" data-kid=\"3-2-1-2-4-1\" data-name=\"active rings label\">Active Rings</span>\n<span class=\"text-xl font-['Space_Grotesk'] font-bold text-cyan-400\" data-kid=\"3-2-1-2-4-2\" data-name=\"active rings value\">03</span>\n</div>\n</div>\n<div class=\"mt-6 pt-6 border-t border-white/5\" data-kid=\"3-2-1-3\" data-name=\"map utilization stats container\">\n<div class=\"flex justify-between items-center mb-2\" data-kid=\"3-2-1-3-1\" data-name=\"utilization header\">\n<span class=\"text-[10px] uppercase text-zinc-400\" data-kid=\"3-2-1-3-1-1\" data-name=\"utilization label\">Map Utilization</span>\n<span class=\"text-[10px] font-mono text-cyan-400\" data-kid=\"3-2-1-3-1-2\" data-name=\"utilization percentage text\">88.4%</span>\n</div>\n<div class=\"h-1 w-full bg-white/10 rounded-full overflow-hidden\" data-kid=\"3-2-1-3-2\" data-name=\"utilization progress bar track\">\n<div class=\"h-full bg-cyan-400\" data-kid=\"3-2-1-3-2-1\" data-name=\"utilization progress bar fill\" style=\"width: 88%\"></div>\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"fixed bottom-8 right-8 flex items-end gap-6 pointer-events-auto\" data-kid=\"3-3\" data-name=\"bottom right control panel\">\n\n<div class=\"staggered-card pellucid-glass signature-geometry p-5 w-72 mb-8 animate-in slide-in-from-bottom-4 fade-in duration-700\" data-kid=\"3-3-1\" data-name=\"network health card\">\n<div class=\"flex items-center justify-between mb-4\" data-kid=\"3-3-1-1\" data-name=\"network health header\">\n<h3 class=\"font-['Space_Grotesk'] text-xs font-bold uppercase tracking-widest\" data-kid=\"3-3-1-1-1\" data-name=\"network health title\">Network Health</h3>\n<span class=\"flex h-2 w-2 rounded-full bg-emerald-500 animate-pulse\" data-kid=\"3-3-1-1-2\" data-name=\"status pulse indicator\"></span>\n</div>\n<div class=\"space-y-3\" data-kid=\"3-3-1-2\" data-name=\"health metrics list\">\n<div class=\"flex justify-between text-xs\" data-kid=\"3-3-1-2-1\" data-name=\"node sync metric\">\n<span class=\"text-zinc-500\" data-kid=\"3-3-1-2-1-1\" data-name=\"node sync label\">Node Sync</span>\n<span class=\"text-zinc-200\" data-kid=\"3-3-1-2-1-2\" data-name=\"node sync value\">Operational</span>\n</div>\n<div class=\"flex justify-between text-xs\" data-kid=\"3-3-1-2-2\" data-name=\"latency metric\">\n<span class=\"text-zinc-500\" data-kid=\"3-3-1-2-2-1\" data-name=\"latency label\">Latency</span>\n<span class=\"text-zinc-200\" data-kid=\"3-3-1-2-2-2\" data-name=\"latency value\">14ms</span>\n</div>\n<div class=\"flex justify-between text-xs\" data-kid=\"3-3-1-2-3\" data-name=\"uptime metric\">\n<span class=\"text-zinc-500\" data-kid=\"3-3-1-2-3-1\" data-name=\"uptime label\">Uptime</span>\n<span class=\"text-zinc-200\" data-kid=\"3-3-1-2-3-2\" data-name=\"uptime value\">99.98%</span>\n</div>\n</div>\n</div>\n\n<div class=\"staggered-card pellucid-glass signature-geometry p-1 flex flex-col w-56 animate-in slide-in-from-bottom-8 fade-in duration-1000\" data-kid=\"3-3-2\" data-name=\"intelligence core fusion card\">\n<div class=\"relative w-full aspect-square overflow-hidden mb-1\" data-kid=\"3-3-2-1\" data-name=\"intelligence core image container\">\n<img alt=\"Core\" class=\"w-full h-full object-cover\" data-kid=\"3-3-2-1-1\" data-name=\"intelligence core image\" src=\"https://images.unsplash.com/photo-1672080070762-764c74ee1227?auto=format&amp;w=600&amp;q=80&amp;fit=crop\">\n<div class=\"absolute inset-0 bg-gradient-to-t from-[#0B0C10] to-transparent\" data-kid=\"3-3-2-1-2\" data-name=\"core image gradient overlay\"></div>\n<div class=\"absolute bottom-4 left-4 right-4\" data-kid=\"3-3-2-1-3\" data-name=\"intelligence core description container\">\n<span class=\"text-[9px] uppercase tracking-widest text-cyan-400 font-bold\" data-kid=\"3-3-2-1-3-1\" data-name=\"intelligence core label\">Intelligence Core</span>\n<p class=\"text-[11px] text-zinc-400 leading-relaxed mt-1\" data-kid=\"3-3-2-1-3-2\" data-name=\"intelligence core description\">Ready for fusion correlation</p>\n</div>\n</div>\n<button class=\"w-full bg-cyan-500 hover:bg-cyan-400 text-black font-bold py-4 text-xs uppercase tracking-[0.2em] transition-all active:scale-95\" data-kid=\"3-3-2-2\" data-name=\"run fusion call-to-action button\" id=\"fusion-btn\">\n        Run Fusion\n      </button>\n</div>\n</div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"6\"></script>\n<script type=\"module\" data-kid=\"7\">\n  import { animate, stagger, scroll } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n  // 1. Initial Entrances\n  animate(\".pellucid-glass\", \n    { opacity: [0, 1], y: [20, 0] },\n    { delay: stagger(0.1), duration: 0.8, ease: [0.22, 1, 0.36, 1] }\n  );\n\n  // 2. Momentum Squish Effect on Navigation\n  const navItems = document.querySelectorAll('.nav-item');\n  navItems.forEach(item => {\n    item.addEventListener('mouseenter', () => {\n      animate(item, { scaleX: 1.1, scaleY: 0.9, y: -2 }, { type: \"spring\", stiffness: 400, damping: 20 });\n    });\n    item.addEventListener('mouseleave', () => {\n      animate(item, { scaleX: 1, scaleY: 1, y: 0 }, { type: \"spring\", stiffness: 400, damping: 20 });\n    });\n  });\n\n  // 3. Fusion Button Physics\n  const fusionBtn = document.getElementById('fusion-btn');\n  fusionBtn.addEventListener('mousedown', () => {\n    animate(fusionBtn, { scale: 0.94, filter: \"brightness(1.5)\" }, { duration: 0.1 });\n  });\n  fusionBtn.addEventListener('mouseup', () => {\n    animate(fusionBtn, { scale: 1, filter: \"brightness(1)\" }, { type: \"spring\", bounce: 0.5 });\n  });\n\n  // 4. Staggered HUD hover effects\n  document.querySelectorAll('.staggered-card').forEach(card => {\n    card.addEventListener('mouseenter', () => {\n      animate(card, { y: -8, boxShadow: \"0 20px 40px rgba(0,0,0,0.6)\" }, { duration: 0.3 });\n    });\n    card.addEventListener('mouseleave', () => {\n      animate(card, { y: 0, boxShadow: \"0 8px 32px rgba(0,0,0,0.4)\" }, { duration: 0.3 });\n    });\n  });\n\n</script>\n\n<script src=\"https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.js\" data-kid=\"8\"></script>\n<link data-kid=\"4\" data-name=\"map library styles\" href=\"https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.css\" rel=\"stylesheet\">\n<script data-kid=\"9\">\n  // Simple initialization of a dark themed map\n  const map = new maplibregl.Map({\n    container: 'map',\n    style: {\n      version: 8,\n      sources: {\n        'osm': {\n          'type': 'raster',\n          'tiles': [\n            'https://cartodb-basemaps-a.global.ssl.fastly.net/dark_all/{z}/{x}/{y}.png'\n          ],\n          'tileSize': 256\n        }\n      },\n      layers: [{\n        'id': 'osm',\n        'type': 'raster',\n        'source': 'osm',\n        'minzoom': 0,\n        'maxzoom': 18,\n        'paint': {\n          'raster-opacity': 0.8,\n          'raster-contrast': 0.2,\n          'raster-brightness-min': 0,\n          'raster-brightness-max': 0.5\n        }\n      }]\n    },\n    center: [77.1025, 28.7041], // Delhi\n    zoom: 12,\n    interactive: true\n  });\n</script>\n<link data-kid=\"5\" data-name=\"tabler icon library\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" rel=\"stylesheet\">",
