      "html": "<link data-kid=\"1\" data-name=\"google fonts preconnect link\" href=\"https://fonts.googleapis.com\" rel=\"preconnect\">\n<link crossorigin=\"\" data-kid=\"2\" data-name=\"google gstatic preconnect link\" href=\"https://fonts.gstatic.com\" rel=\"preconnect\">\n<link data-kid=\"3\" data-name=\"google fonts stylesheet link\" href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&amp;family=Teko:wght@300;400;500;600;700&amp;display=swap\" rel=\"stylesheet\">\n<link data-kid=\"4\" data-name=\"tabler icons stylesheet link\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" rel=\"stylesheet\">\n<style data-kid=\"0\">\n  :root {\n    --space-black: #050507;\n    --command-crimson: #8B2635;\n    --titanium-silver: #E2E2E8;\n    --radar-amber: #D97706;\n  }\n\n  body {\n    margin: 0;\n    font-family: 'Inter', sans-serif;\n    background-color: var(--space-black);\n    color: var(--titanium-silver);\n    overflow: hidden;\n    height: 100vh;\n  }\n\n  .font-teko { font-family: 'Teko', sans-serif; }\n\n  /* L-Bracket Navigation */\n  .l-bracket {\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 80px;\n    height: 100vh;\n    background: rgba(5, 5, 7, 0.85);\n    backdrop-filter: blur(24px);\n    border-right: 1px solid rgba(139, 38, 53, 0.3);\n    z-index: 50;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding-top: 24px;\n  }\n\n  .l-bracket-top {\n    position: fixed;\n    top: 0;\n    left: 0;\n    right: 0;\n    height: 64px;\n    background: rgba(5, 5, 7, 0.85);\n    backdrop-filter: blur(24px);\n    border-bottom: 1px solid rgba(139, 38, 53, 0.3);\n    z-index: 40;\n    display: flex;\n    align-items: center;\n    padding-left: 100px;\n    padding-right: 24px;\n    justify-content: space-between;\n  }\n\n  /* Curve the corner */\n  .l-bracket-corner {\n    position: fixed;\n    top: 64px;\n    left: 80px;\n    width: 32px;\n    height: 32px;\n    background: transparent;\n    border-top-left-radius: 24px;\n    box-shadow: -16px -16px 0 16px rgba(5, 5, 7, 0.85);\n    z-index: 45;\n    pointer-events: none;\n  }\n\n  /* Spline Background */\n  .spline-scene {\n    position: fixed;\n    inset: 0;\n    z-index: 0;\n    background: radial-gradient(circle at center, #0a0a0f 0%, #050507 100%);\n  }\n\n  .spline-scene__frame {\n    width: 140%;\n    height: 140%;\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    border: none;\n    opacity: 0;\n    transition: opacity 1.5s ease;\n  }\n\n  .is-ready .spline-scene__frame {\n    opacity: 0.6;\n  }\n\n  /* Command Pill */\n  .command-pill {\n    position: fixed;\n    bottom: 32px;\n    left: 50%;\n    transform: translateX(-50%);\n    width: 600px;\n    height: 80px;\n    background: rgba(5, 5, 7, 0.9);\n    backdrop-filter: blur(32px);\n    border: 1px solid rgba(139, 38, 53, 0.4);\n    border-radius: 100px;\n    z-index: 100;\n    display: flex;\n    align-items: center;\n    padding: 0 8px;\n    box-shadow: 0 20px 50px rgba(0,0,0,0.8), 0 0 20px rgba(139, 38, 53, 0.2);\n  }\n\n  .terminal-feed {\n    flex: 1;\n    height: 48px;\n    overflow: hidden;\n    padding: 0 24px;\n    font-size: 11px;\n    color: rgba(226, 226, 232, 0.7);\n    line-height: 1.4;\n    mask-image: linear-gradient(to bottom, transparent, black 20%, black 80%, transparent);\n  }\n\n  .fusion-btn {\n    width: 64px;\n    height: 64px;\n    border-radius: 50%;\n    background: var(--command-crimson);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n    position: relative;\n    overflow: hidden;\n    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);\n  }\n\n  .fusion-btn:hover {\n    transform: scale(1.05);\n  }\n\n  .fusion-btn i {\n    font-size: 24px;\n    color: white;\n    z-index: 2;\n  }\n\n  .fusion-btn::after {\n    content: '';\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(45deg, transparent, rgba(255,255,255,0.2), transparent);\n    transform: translateX(-100%);\n    animation: shimmer 3s infinite;\n  }\n\n  @keyframes shimmer {\n    100% { transform: translateX(100%); }\n  }\n\n  /* HUD Overlays */\n  .hud-stat {\n    position: absolute;\n    background: rgba(139, 38, 53, 0.05);\n    border: 1px solid rgba(139, 38, 53, 0.2);\n    padding: 16px;\n    border-radius: 8px;\n    backdrop-filter: blur(8px);\n  }\n\n  .nav-item {\n    width: 48px;\n    height: 48px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    border-radius: 12px;\n    color: rgba(226, 226, 232, 0.5);\n    margin-bottom: 12px;\n    transition: all 0.3s;\n    cursor: pointer;\n  }\n\n  .nav-item.active {\n    background: var(--command-crimson);\n    color: white;\n    box-shadow: 0 4px 12px rgba(139, 38, 53, 0.4);\n  }\n\n  .nav-item:hover:not(.active) {\n    background: rgba(255,255,255,0.05);\n    color: var(--titanium-silver);\n  }\n\n  /* Pretext Canvas Container */\n  #pretext-container {\n    width: 100%;\n    height: 100%;\n  }\n\n</style>\n<div class=\"spline-scene\" data-kid=\"5\" data-name=\"spline scene container\" id=\"spline-scene\">\n<iframe allow=\"autoplay; fullscreen\" class=\"spline-scene__frame\" data-dynamic=\"true\" data-kid=\"5-1\" data-name=\"3D quantum core visualizer iframe\" data-reason=\"src URL reinitialized and content loaded by Spline library\" loading=\"lazy\" src=\"https://my.spline.design/interactiveaiwebsite-YVqztj39V6lVDAFkMZnJyGWf/\" title=\"Quantum Core Visualizer\"></iframe>\n</div>\n<aside class=\"l-bracket\" data-kid=\"6\" data-name=\"l-bracket navigation bar\">\n<div class=\"mb-8 p-4\" data-kid=\"6-1\" data-name=\"nav top logo container\">\n<div class=\"w-8 h-8 rounded bg-white flex items-center justify-center\" data-kid=\"6-1-1\" data-name=\"shield logo wrapper\">\n<i class=\"ti ti-shield-check text-black text-xl\" data-kid=\"6-1-1-1\" data-name=\"shield check icon\"></i>\n</div>\n</div>\n<nav data-kid=\"6-2\" data-name=\"navigation link container\">\n<div class=\"nav-item active\" data-kid=\"6-2-1\" data-name=\"live intelligence map nav item\" title=\"Live Intelligence Map\">\n<i class=\"ti ti-layout-dashboard\" data-kid=\"6-2-1-1\" data-name=\"dashboard icon\"></i>\n</div>\n<div class=\"nav-item\" data-kid=\"6-2-2\" data-name=\"fraud rings analysis nav item\" title=\"Fraud Rings Analysis\">\n<i class=\"ti ti-fingerprint\" data-kid=\"6-2-2-1\" data-name=\"fingerprint icon\"></i>\n</div>\n<div class=\"nav-item\" data-kid=\"6-2-3\" data-name=\"network activity nav item\" title=\"Network Activity\">\n<i class=\"ti ti-activity\" data-kid=\"6-2-3-1\" data-name=\"activity pulse icon\"></i>\n</div>\n<div class=\"nav-item\" data-kid=\"6-2-4\" data-name=\"global archives nav item\" title=\"Global Archives\">\n<i class=\"ti ti-archive\" data-kid=\"6-2-4-1\" data-name=\"archive box icon\"></i>\n</div>\n</nav>\n<div class=\"mt-auto mb-6\" data-kid=\"6-3\" data-name=\"nav bottom settings container\">\n<div class=\"nav-item\" data-kid=\"6-3-1\" data-name=\"system settings nav item\" title=\"System Settings\">\n<i class=\"ti ti-settings\" data-kid=\"6-3-1-1\" data-name=\"settings gear icon\"></i>\n</div>\n</div>\n</aside>\n<header class=\"l-bracket-top\" data-kid=\"7\" data-name=\"top header bar\">\n<div class=\"flex items-center gap-4\" data-kid=\"7-1\" data-name=\"header title and status container\">\n<h2 class=\"font-teko text-2xl tracking-[0.2em] uppercase text-zinc-400\" data-kid=\"7-1-1\" data-name=\"quantum console header text\">Quantum Console <span class=\"text-zinc-600\" data-kid=\"7-1-1-1\" data-name=\"system version number text\">v4.0.2</span></h2>\n<div class=\"flex items-center gap-2 px-3 py-1 bg-emerald-500/10 border border-emerald-500/20 rounded-full\" data-kid=\"7-1-2\" data-name=\"system link status pill\">\n<div class=\"w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse\" data-kid=\"7-1-2-1\" data-name=\"system status pulse indicator\"></div>\n<span class=\"text-[10px] uppercase tracking-widest font-medium text-emerald-500\" data-kid=\"7-1-2-2\" data-name=\"system link status text\">System Link Stable</span>\n</div>\n</div>\n<div class=\"flex items-center gap-6\" data-kid=\"7-2\" data-name=\"header profile and alert container\">\n<div class=\"flex items-center gap-3\" data-kid=\"7-2-1\" data-name=\"duty officer profile container\">\n<div class=\"text-right\" data-kid=\"7-2-1-1\" data-name=\"duty officer name container\">\n<div class=\"text-[10px] uppercase tracking-tighter text-zinc-500\" data-kid=\"7-2-1-1-1\" data-name=\"duty officer label text\">Duty Officer</div>\n<div class=\"text-xs font-medium\" data-kid=\"7-2-1-1-2\" data-name=\"duty officer id text\">PM. AEGIS-1</div>\n</div>\n<div class=\"w-10 h-10 rounded-full border border-[var(--command-crimson)] p-0.5\" data-kid=\"7-2-1-2\" data-name=\"avatar image container\">\n<img alt=\"avatar\" class=\"w-full h-full rounded-full grayscale\" data-kid=\"7-2-1-2-1\" data-name=\"duty officer avatar image\" src=\"https://i.pravatar.cc/100?u=aegis\">\n</div>\n</div>\n<button class=\"relative w-10 h-10 flex items-center justify-center rounded-lg hover:bg-zinc-800 transition-colors\" data-kid=\"7-2-2\" data-name=\"notifications bell button\">\n<i class=\"ti ti-bell text-xl\" data-kid=\"7-2-2-1\" data-name=\"bell icon\"></i>\n<span class=\"absolute top-2 right-2 w-2 h-2 bg-[var(--command-crimson)] rounded-full ring-2 ring-black\" data-kid=\"7-2-2-2\" data-name=\"notification unread indicator\"></span>\n</button>\n</div>\n</header>\n<div class=\"l-bracket-corner\" data-kid=\"8\" data-name=\"nav corner bracket decoration\"></div>\n<div class=\"relative z-10 pl-[120px] pt-[100px]\" data-kid=\"9\" data-name=\"main content layout wrapper\">\n<div class=\"max-w-2xl\" data-kid=\"9-1\" data-name=\"hero section text container\">\n<h1 class=\"font-teko text-7xl font-light tracking-tight text-white leading-[0.9] opacity-0 reveal-y\" data-kid=\"9-1-1\" data-name=\"hero headline text\">\n      INTELLIGENCE<br data-kid=\"9-1-1-1\" data-name=\"headline line break\"><span class=\"text-[var(--command-crimson)]\" data-kid=\"9-1-1-2\" data-name=\"hero headline fusion text\">FUSION</span> COMMAND\n    </h1>\n<p class=\"mt-6 text-zinc-400 max-w-md text-sm leading-relaxed opacity-0 reveal-y\" data-kid=\"9-1-2\" data-name=\"hero description text\" style=\"transition-delay: 0.1s\">\n      Real-time cross-domain correlation for public safety. Monitoring scam signals, counterfeit distributions, and organized fraud networks.\n    </p>\n<div class=\"mt-12 flex gap-8\" data-kid=\"9-1-3\" data-name=\"hero stats container\">\n<div class=\"opacity-0 reveal-y\" data-kid=\"9-1-3-1\" data-name=\"active signals stat card\" style=\"transition-delay: 0.2s\">\n<div class=\"text-[10px] uppercase tracking-[0.2em] text-zinc-500 mb-1\" data-kid=\"9-1-3-1-1\" data-name=\"active signals label\">Active Signals</div>\n<div class=\"font-teko text-5xl text-white\" data-kid=\"9-1-3-1-2\" data-name=\"active signals counter\">4,892</div>\n</div>\n<div class=\"opacity-0 reveal-y\" data-kid=\"9-1-3-2\" data-name=\"threat index stat card\" style=\"transition-delay: 0.3s\">\n<div class=\"text-[10px] uppercase tracking-[0.2em] text-zinc-500 mb-1\" data-kid=\"9-1-3-2-1\" data-name=\"threat index label\">Threat Index</div>\n<div class=\"font-teko text-5xl text-[var(--command-crimson)]\" data-kid=\"9-1-3-2-2\" data-name=\"threat index value text\">High</div>\n</div>\n<div class=\"opacity-0 reveal-y\" data-kid=\"9-1-3-3\" data-name=\"node uptime stat card\" style=\"transition-delay: 0.4s\">\n<div class=\"text-[10px] uppercase tracking-[0.2em] text-zinc-500 mb-1\" data-kid=\"9-1-3-3-1\" data-name=\"node uptime label\">Node Uptime</div>\n<div class=\"font-teko text-5xl text-white\" data-kid=\"9-1-3-3-2\" data-name=\"node uptime percentage text\">99.98%</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"command-pill opacity-0 reveal-dock\" data-kid=\"10\" data-name=\"command pill container\">\n<div class=\"flex gap-4 px-6 border-r border-zinc-800/50 mr-4\" data-kid=\"10-1\" data-name=\"command pill counters container\">\n<div class=\"text-center\" data-kid=\"10-1-1\" data-name=\"scams counter container\">\n<div class=\"text-[9px] uppercase tracking-tighter text-zinc-500\" data-kid=\"10-1-1-1\" data-name=\"scams label\">Scams</div>\n<div class=\"font-teko text-xl text-white\" data-kid=\"10-1-1-2\" data-name=\"scams counter\">124</div>\n</div>\n<div class=\"text-center\" data-kid=\"10-1-2\" data-name=\"rings counter container\">\n<div class=\"text-[9px] uppercase tracking-tighter text-zinc-500\" data-kid=\"10-1-2-1\" data-name=\"rings label\">Rings</div>\n<div class=\"font-teko text-xl text-white\" data-kid=\"10-1-2-2\" data-name=\"rings counter\">12</div>\n</div>\n</div>\n<div class=\"terminal-feed\" data-kid=\"10-2\" data-name=\"terminal feed container\" id=\"terminal-feed\">\n<div class=\"w-full\" data-dynamic=\"true\" data-kid=\"10-2-1\" data-name=\"terminal feed content container\" data-reason=\"content rendered and injected by Pretext library\" id=\"pretext-target\"></div>\n</div>\n<div class=\"flex items-center gap-3 pr-2\" data-kid=\"10-3\" data-name=\"command action buttons container\">\n<div class=\"text-right hidden sm:block\" data-kid=\"10-3-1\" data-name=\"correlation status container\">\n<div class=\"text-[9px] uppercase tracking-tighter text-zinc-500\" data-kid=\"10-3-1-1\" data-name=\"correlation label\">Correlation</div>\n<div class=\"text-[10px] font-medium text-zinc-300\" data-kid=\"10-3-1-2\" data-name=\"correlation status text\">Ready for Fusion</div>\n</div>\n<button class=\"fusion-btn\" data-kid=\"10-3-2\" data-name=\"fusion trigger button\" id=\"fusion-trigger\">\n<i class=\"ti ti-bolt\" data-kid=\"10-3-2-1\" data-name=\"lightning bolt icon\"></i>\n</button>\n</div>\n</div>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"11\"></script>\n<script type=\"module\" data-kid=\"12\">\n  // Pretext library integration for high-density terminal layout\n  import { prepare } from 'https://cdn.jsdelivr.net/npm/@chenglou/pretext@0.0.8/+esm';\n\n  const terminalContainer = document.getElementById('pretext-target');\n  const feedContent = [\n    \"[SYSTEM] Synchronizing node cluster AEGIS-7...\",\n    \"[SIGNAL] Anomaly detected in District 4 (Jamtara) - Scam score > 0.85\",\n    \"[CORE] Intelligence Fusion standing by. Processing 489 active events.\",\n    \"[NETWORK] Encrypted fraud-ring communication intercepted. Mapping edges...\",\n    \"[INFO] Satellite view updated. Resolving hotspot coordinates.\",\n    \"[AUTH] Duty Officer PM. AEGIS-1 logged in. Level 4 Clearance confirmed.\",\n    \"[WARNING] Large-scale counterfeit distribution detected in Mumbai South.\"\n  ];\n\n  function renderTerminal() {\n    const width = terminalContainer.offsetWidth;\n    const fullText = feedContent.join('\\n');\n    \n    // Pretext helps with measurement and layout without DOM reflow\n    const prepared = prepare(fullText, {\n      width: width,\n      fontSize: 11,\n      lineHeight: 16,\n      fontFamily: 'Inter, sans-serif'\n    });\n\n    // Simple renderer for the demonstration\n    terminalContainer.innerHTML = '';\n    prepared.lines.forEach(line => {\n      const p = document.createElement('p');\n      p.className = 'whitespace-pre';\n      p.textContent = line.text;\n      terminalContainer.appendChild(p);\n    });\n  }\n\n  // Initial render\n  renderTerminal();\n\n  // Scroll the terminal feed\n  let offset = 0;\n  setInterval(() => {\n    offset += 16;\n    if (offset >= terminalContainer.scrollHeight - 48) offset = 0;\n    gsap.to(terminalContainer, { y: -offset, duration: 1, ease: \"power2.inOut\" });\n  }, 3000);\n\n  // Spline load handler\n  const splineWrapper = document.getElementById('spline-scene');\n  const iframe = splineWrapper.querySelector('iframe');\n  iframe.addEventListener('load', () => {\n    splineWrapper.classList.add('is-ready');\n  });\n\n  // Entrance animations\n  gsap.to(\".reveal-y\", {\n    y: 0,\n    opacity: 1,\n    duration: 1,\n    stagger: 0.15,\n    ease: \"power4.out\",\n    delay: 0.5\n  });\n\n  gsap.to(\".reveal-dock\", {\n    opacity: 1,\n    y: 0,\n    duration: 1.2,\n    ease: \"expo.out\",\n    delay: 1.2\n  });\n\n  // Trigger effect\n  const btn = document.getElementById('fusion-trigger');\n  btn.onclick = () => {\n    gsap.to(btn, { scale: 0.9, duration: 0.1 });\n    gsap.to(btn, { scale: 1, duration: 0.4, ease: \"back.out(2)\" });\n    \n    // Brief flare effect\n    const flare = document.createElement('div');\n    flare.className = 'fixed inset-0 pointer-events-none z-[200] bg-white';\n    document.body.appendChild(flare);\n    gsap.to(flare, { opacity: 0, duration: 1.5, onComplete: () => flare.remove() });\n  };\n</script>",
