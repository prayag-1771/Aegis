      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Playfair+Display:ital,wght@0,700;1,700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    margin: 0;\n    padding: 0;\n    background-color: #161618;\n    color: #F3F3F5;\n    font-family: 'Inter', sans-serif;\n    overflow: hidden;\n    height: 100vh;\n  }\n\n  .font-serif { font-family: 'Playfair Display', serif; }\n\n  /* --- Spline Background --- */\n  .spline-scene {\n    position: fixed;\n    inset: 0;\n    z-index: 0;\n    background: #000;\n  }\n  .spline-scene__frame {\n    width: 100%;\n    height: 100%;\n    border: 0;\n    opacity: 0;\n    transition: opacity 1.5s ease;\n  }\n  .spline-scene.is-ready .spline-scene__frame {\n    opacity: 0.7;\n  }\n\n  /* --- Navigation (Orbicular Cluster) --- */\n  .orbicular-nav {\n    position: fixed;\n    left: 24px;\n    top: 50%;\n    transform: translateY(-50%);\n    z-index: 50;\n    display: flex;\n    flex-direction: column;\n    gap: 16px;\n  }\n  .nav-circle {\n    width: 48px;\n    height: 48px;\n    border-radius: 50%;\n    background: rgba(22, 22, 24, 0.8);\n    border: 1px solid rgba(243, 243, 245, 0.1);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n    transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);\n    color: rgba(243, 243, 245, 0.6);\n    backdrop-filter: blur(12px);\n  }\n  .nav-circle:hover, .nav-circle.active {\n    background: #3B82F6;\n    color: #fff;\n    border-color: #3B82F6;\n    box-shadow: 0 0 20px rgba(59, 130, 246, 0.4);\n  }\n  .nav-circle i { font-size: 20px; }\n\n  /* --- Top Bar (Hemstitched) --- */\n  .top-bar {\n    position: fixed;\n    top: 0;\n    left: 0;\n    right: 0;\n    height: 72px;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    padding: 0 32px;\n    z-index: 40;\n  }\n  .hemstitch-top {\n    position: absolute;\n    bottom: 0;\n    left: 32px;\n    right: 32px;\n    height: 1px;\n  }\n\n  /* --- Bottom Terminal (Brainpower) --- */\n  .bottom-terminal {\n    position: fixed;\n    bottom: 32px;\n    left: 96px;\n    right: 32px;\n    background: rgba(22, 22, 24, 0.85);\n    backdrop-filter: blur(20px);\n    border-radius: 4px;\n    padding: 24px;\n    z-index: 40;\n    display: flex;\n    justify-content: space-between;\n    align-items: flex-end;\n  }\n  .hemstitch-box {\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n  }\n\n  /* --- Editorial Alert List --- */\n  .alert-drawer {\n    position: fixed;\n    top: 104px;\n    right: 32px;\n    width: 320px;\n    background: #F3F3F5;\n    color: #161618;\n    padding: 32px;\n    border-radius: 2px;\n    z-index: 40;\n    box-shadow: 20px 20px 60px rgba(0,0,0,0.5);\n  }\n  .alert-item {\n    border-bottom: 1px dotted #161618;\n    padding: 16px 0;\n    display: flex;\n    gap: 16px;\n  }\n  .alert-index {\n    font-size: 24px;\n    line-height: 1;\n    font-weight: 700;\n    opacity: 0.3;\n  }\n\n  /* --- Fusion Button --- */\n  .fusion-orb {\n    width: 64px;\n    height: 64px;\n    border-radius: 50%;\n    background: #3B82F6;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n    box-shadow: 0 0 30px rgba(59, 130, 246, 0.6);\n    position: relative;\n    overflow: hidden;\n  }\n  .fusion-orb::after {\n    content: '';\n    position: absolute;\n    inset: 0;\n    background: radial-gradient(circle, rgba(255,255,255,0.4) 0%, transparent 70%);\n    animation: orb-pulse 2s infinite;\n  }\n\n  @keyframes orb-pulse {\n    0% { transform: scale(0.8); opacity: 0.5; }\n    50% { transform: scale(1.1); opacity: 0.8; }\n    100% { transform: scale(0.8); opacity: 0.5; }\n  }\n\n  /* --- Hemstitching SVG Paths --- */\n  .hemstitch-path {\n    fill: none;\n    stroke: rgba(243, 243, 245, 0.2);\n    stroke-width: 1;\n    stroke-dasharray: 4 4;\n  }\n  .hemstitch-dark {\n    stroke: rgba(22, 22, 24, 0.2);\n  }\n\n  /* --- Map Placeholder --- */\n  .map-underlay {\n    position: absolute;\n    inset: 0;\n    z-index: 1;\n    opacity: 0.3;\n    pointer-events: none;\n  }\n\n</style>\n<div class=\"spline-scene\" data-kid=\"1\" data-name=\"spline 3d background scene container\" id=\"spline-container\">\n<iframe allow=\"autoplay; fullscreen\" class=\"spline-scene__frame\" data-kid=\"1-1\" data-name=\"spline 3d interactive iframe\" id=\"spline-frame\" loading=\"lazy\" src=\"https://my.spline.design/particleaibrain-X859vknw1IEXe3nJFRI24a0s/\" title=\"particleaibrain — 3D scene\"></iframe>\n</div>\n<nav class=\"orbicular-nav\" data-kid=\"2\" data-name=\"orbicular navigation cluster\">\n<div class=\"nav-circle active\" data-kid=\"2-1\" data-name=\"active navigation circle\"><i class=\"ti ti-map\" data-kid=\"2-1-1\" data-name=\"map icon\"></i></div>\n<div class=\"nav-circle\" data-kid=\"2-2\" data-name=\"navigation circle\"><i class=\"ti ti-crosshair\" data-kid=\"2-2-1\" data-name=\"crosshair icon\"></i></div>\n<div class=\"nav-circle\" data-kid=\"2-3\" data-name=\"navigation circle\"><i class=\"ti ti-layers-intersect\" data-kid=\"2-3-1\" data-name=\"layers intersect icon\"></i></div>\n<div class=\"nav-circle mt-12 opacity-50\" data-kid=\"2-4\" data-name=\"settings navigation circle\"><i class=\"ti ti-settings\" data-kid=\"2-4-1\" data-name=\"settings icon\"></i></div>\n</nav>\n<header class=\"top-bar\" data-kid=\"3\" data-name=\"top bar layout container\">\n<div class=\"flex items-center gap-4\" data-kid=\"3-1\" data-name=\"brand and version container\">\n<h1 class=\"font-serif text-3xl tracking-tight italic\" data-kid=\"3-1-1\" data-name=\"aegis intelligence hero headline\">Aegis Intelligence</h1>\n<span class=\"text-[10px] uppercase tracking-[0.3em] text-zinc-500 mt-2\" data-kid=\"3-1-2\" data-name=\"version identifier text\">v.04 Precision Protocol</span>\n</div>\n<div class=\"flex items-center gap-6\" data-kid=\"3-2\" data-name=\"user and system status container\">\n<div class=\"flex gap-1\" data-kid=\"3-2-1\" data-name=\"status indicator container\">\n<div class=\"w-1.5 h-1.5 rounded-full bg-emerald-500\" data-kid=\"3-2-1-1\" data-name=\"status indicator node\"></div>\n<div class=\"w-1.5 h-1.5 rounded-full bg-emerald-500\" data-kid=\"3-2-1-2\" data-name=\"status indicator node\"></div>\n<div class=\"w-1.5 h-1.5 rounded-full bg-zinc-700\" data-kid=\"3-2-1-3\" data-name=\"inactive status indicator node\"></div>\n</div>\n<div class=\"relative\" data-kid=\"3-2-2\" data-name=\"user profile container\">\n<img alt=\"Rachel McDermott on Unsplash\" class=\"w-10 h-10 rounded-full border border-white/10 grayscale hover:grayscale-0 transition-all duration-500\" data-kid=\"3-2-2-1\" data-name=\"user profile image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1558730234-d8b2281b0d00?auto=format&amp;w=80&amp;q=80&amp;fit=crop\">\n</div>\n</div>\n<svg class=\"hemstitch-top\" data-kid=\"3-3\" data-name=\"top hemstitch decorative line\" height=\"1\" width=\"100%\">\n<line class=\"hemstitch-path\" id=\"top-line\" x1=\"0\" x2=\"100%\" y1=\"0.5\" y2=\"0.5\" data-kid=\"6\"></line>\n</svg>\n</header>\n<div class=\"alert-drawer animate-slide-in\" data-kid=\"4\" data-name=\"editorial alert drawer\">\n<h2 class=\"font-serif text-2xl italic mb-6\" data-kid=\"4-1\" data-name=\"active signals section title\">Active Signals</h2>\n<div class=\"alert-item\" data-kid=\"4-2\" data-name=\"financial anomaly alert item\">\n<span class=\"alert-index font-serif\" data-kid=\"4-2-1\" data-name=\"alert index number\">01</span>\n<div data-kid=\"4-2-2\" data-name=\"alert details container\">\n<h3 class=\"font-semibold text-xs uppercase tracking-wider mb-1\" data-kid=\"4-2-2-1\" data-name=\"alert title\">Financial Anomaly</h3>\n<p class=\"text-[11px] leading-relaxed opacity-80\" data-kid=\"4-2-2-2\" data-name=\"alert description text\">Jamtara District · High velocity outflow detected across 14 synchronized nodes.</p>\n</div>\n</div>\n<div class=\"alert-item\" data-kid=\"4-3\" data-name=\"currency breach alert item\">\n<span class=\"alert-index font-serif\" data-kid=\"4-3-1\" data-name=\"alert index number\">02</span>\n<div data-kid=\"4-3-2\" data-name=\"alert details container\">\n<h3 class=\"font-semibold text-xs uppercase tracking-wider mb-1\" data-kid=\"4-3-2-1\" data-name=\"alert title\">Currency Breach</h3>\n<p class=\"text-[11px] leading-relaxed opacity-80\" data-kid=\"4-3-2-2\" data-name=\"alert description text\">Mumbai South · Visual scan confirmed counterfeit Series-7 notes in circulation.</p>\n</div>\n</div>\n<div class=\"alert-item border-none\" data-kid=\"4-4\" data-name=\"social engineering alert item\">\n<span class=\"alert-index font-serif\" data-kid=\"4-4-1\" data-name=\"alert index number\">03</span>\n<div data-kid=\"4-4-2\" data-name=\"alert details container\">\n<h3 class=\"font-semibold text-xs uppercase tracking-wider mb-1\" data-kid=\"4-4-2-1\" data-name=\"alert title\">Social Engineering</h3>\n<p class=\"text-[11px] leading-relaxed opacity-80\" data-kid=\"4-4-2-2\" data-name=\"alert description text\">Nuh Corridor · Automated voice-cloning campaign targeting high-net-worth elders.</p>\n</div>\n</div>\n<button class=\"mt-8 w-full py-3 border border-zinc-900 font-semibold text-[10px] uppercase tracking-widest hover:bg-zinc-900 hover:text-white transition-colors\" data-kid=\"4-5\" data-name=\"open full ledger call-to-action button\">\n    Open Full Ledger\n  </button>\n</div>\n<section class=\"bottom-terminal\" data-kid=\"5\" data-name=\"bottom terminal layout container\">\n<svg class=\"hemstitch-box\" data-kid=\"5-1\" data-name=\"bottom hemstitch decorative rectangle\" height=\"100%\" width=\"100%\">\n<rect class=\"hemstitch-path\" height=\"calc(100% - 1px)\" id=\"bottom-rect\" width=\"calc(100% - 1px)\" x=\"0.5\" y=\"0.5\" data-kid=\"7\"></rect>\n</svg>\n<div class=\"flex-1 max-w-2xl\" data-kid=\"5-2\" data-name=\"system metrics container\">\n<div class=\"flex gap-4 mb-4\" data-kid=\"5-2-1\" data-name=\"pretext engine status container\">\n<span class=\"text-[#3B82F6] text-[10px] font-mono tracking-tighter\" data-kid=\"5-2-1-1\" data-name=\"engine status label\">[ PRETEXT_ENGINE_READY ]</span>\n<span class=\"opacity-30 text-[10px] font-mono\" data-kid=\"5-2-1-2\" data-name=\"measurement accuracy indicator\">MEASUREMENT_ACCURACY: 99.998%</span>\n</div>\n<div class=\"grid grid-cols-3 gap-8\" data-kid=\"5-2-2\" data-name=\"metrics grid container\">\n<div data-kid=\"5-2-2-1\" data-name=\"network load metric card\">\n<h4 class=\"text-[10px] uppercase tracking-widest text-zinc-500 mb-2\" data-kid=\"5-2-2-1-1\" data-name=\"network load label\">Network Load</h4>\n<p class=\"font-serif text-2xl\" data-kid=\"5-2-2-1-2\" data-name=\"network load value\">02.4 <span class=\"text-sm italic opacity-50\" data-kid=\"5-2-2-1-2-1\" data-name=\"network load unit\">tbps</span></p>\n</div>\n<div data-kid=\"5-2-2-2\" data-name=\"signal density metric card\">\n<h4 class=\"text-[10px] uppercase tracking-widest text-zinc-500 mb-2\" data-kid=\"5-2-2-2-1\" data-name=\"signal density label\">Signal Density</h4>\n<p class=\"font-serif text-2xl\" data-kid=\"5-2-2-2-2\" data-name=\"signal density value\">842 <span class=\"text-sm italic opacity-50\" data-kid=\"5-2-2-2-2-1\" data-name=\"signal density unit\">pts/sqm</span></p>\n</div>\n<div data-kid=\"5-2-2-3\" data-name=\"fusion confidence metric card\">\n<h4 class=\"text-[10px] uppercase tracking-widest text-zinc-500 mb-2\" data-kid=\"5-2-2-3-1\" data-name=\"fusion confidence label\">Fusion Confidence</h4>\n<p class=\"font-serif text-2xl\" data-kid=\"5-2-2-3-2\" data-name=\"fusion confidence value\">94.1 <span class=\"text-sm italic opacity-50\" data-kid=\"5-2-2-3-2-1\" data-name=\"fusion confidence unit\">%</span></p>\n</div>\n</div>\n</div>\n<div class=\"flex flex-col items-center gap-2\" data-kid=\"5-3\" data-name=\"initiate fusion container\">\n<span class=\"text-[9px] uppercase tracking-[0.4em] text-zinc-500\" data-kid=\"5-3-1\" data-name=\"initiate fusion label\">Initiate Fusion</span>\n<div class=\"fusion-orb\" data-kid=\"5-3-2\" data-name=\"fusion orb button\">\n<i class=\"ti ti-bolt text-white text-2xl\" data-kid=\"5-3-2-1\" data-name=\"lightning bolt icon\"></i>\n</div>\n</div>\n</section>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"8\"></script>\n<script data-kid=\"9\">\n  // Spline Ready State\n  const splineFrame = document.getElementById('spline-frame');\n  const splineContainer = document.getElementById('spline-container');\n  \n  splineFrame.addEventListener('load', () => {\n    splineContainer.classList.add('is-ready');\n  });\n\n  // GSAP Hemstitching Animations\n  window.addEventListener('load', () => {\n    const tl = gsap.timeline({ defaults: { ease: \"power2.inOut\" } });\n\n    // Hemstitch Draw\n    gsap.from(\".hemstitch-path\", {\n      strokeDashoffset: 1000,\n      duration: 2.5,\n      stagger: 0.5,\n      ease: \"power1.inOut\"\n    });\n\n    // Content Entrances\n    tl.from(\".top-bar h1, .top-bar span\", {\n      y: 20,\n      opacity: 0,\n      stagger: 0.1,\n      duration: 0.8\n    }, 0.5);\n\n    tl.from(\".nav-circle\", {\n      x: -40,\n      opacity: 0,\n      stagger: 0.05,\n      duration: 0.6,\n      ease: \"back.out(1.7)\"\n    }, 0.8);\n\n    tl.from(\".alert-drawer\", {\n      x: 50,\n      opacity: 0,\n      duration: 1,\n      ease: \"power3.out\"\n    }, 1);\n\n    tl.from(\".bottom-terminal\", {\n      y: 50,\n      opacity: 0,\n      duration: 1,\n      ease: \"power3.out\"\n    }, 1.2);\n\n    tl.from(\".bottom-terminal .font-serif\", {\n      opacity: 0,\n      y: 10,\n      stagger: 0.1,\n      duration: 0.5\n    }, 1.5);\n  });\n\n  // Mouse interactivity for \"Precision\" vibe\n  document.addEventListener('mousemove', (e) => {\n    const x = (e.clientX / window.innerWidth - 0.5) * 20;\n    const y = (e.clientY / window.innerHeight - 0.5) * 20;\n    \n    gsap.to(\".alert-drawer\", {\n      x: x * 0.5,\n      y: y * 0.5,\n      duration: 1,\n      ease: \"power2.out\"\n    });\n  });\n</script>",
